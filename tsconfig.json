{
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"],

    "exclude": ["dist"],
    "compilerOptions": {
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "strict": true,
        "strictNullChecks": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    }
}
